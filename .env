###> Docker configuration ###
NGINX_PORT=8080
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
###< Docker configuration ###

###> Symfony configuration ###
APP_ENV=dev
APP_SECRET=your_secret_key_here

###> RabbitMQ configuration ###
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=rabbitmq
###< RabbitMQ configuration ###

###> Messenger configuration ###
MESSENGER_TRANSPORT_DSN=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@${RABBITMQ_HOST}:5672/%2f/logs.ingest
###< Messenger configuration ###

###> Routing configuration ###
DEFAULT_URI=http://localhost:${NGINX_PORT}
###< Routing configuration ###
